# BotFather'dan olingan token (majburiy)
BOT_TOKEN=123456:ABC-YourTokenHere
# O'qituvchi(lar) Telegram ID raqami, vergul bilan (ixtiyoriy).
# Bo'sh qoldirsangiz — hamma baza yuklashi va test tuzishi mumkin.
ADMIN_IDS=
# SQLite bazasi yo'li. Railway'da Volume ulasangiz: /data/data.db
DB_PATH=data.db
